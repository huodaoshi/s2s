#!/usr/bin/env bash
# SessionStart（Cursor）：从仓库 .agents/skills/ 注入 harness 会话引导。

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
REPO_ROOT="$(cd "${PLUGIN_ROOT}/.." && pwd)"
_plugin_basename="$(basename "$PLUGIN_ROOT")"

_read_skill_file() {
  tr -d '\r' < "$1"
}

_bootstrap_file="${REPO_ROOT}/.harness/session/session-bootstrap.md"
if [ -f "$_bootstrap_file" ]; then
  bootstrap_content=$(_read_skill_file "$_bootstrap_file")
else
  _skill_list=""
  if [ -d "${REPO_ROOT}/.agents/skills" ]; then
    for _f in "${REPO_ROOT}"/.agents/skills/*/SKILL.md; do
      [ -f "$_f" ] || continue
      _skill_list="${_skill_list}\n- $(basename "$(dirname "$_f")")"
    done
  fi
  bootstrap_content="Harness：技能在 .agents/skills/<name>/SKILL.md。${ _skill_list }\n详见 CLAUDE.md 与 .harness/knowledge/。"
fi

escape_for_json() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/\\n}"
  s="${s//$'\r'/\\r}"
  s="${s//$'\t'/\\t}"
  printf '%s' "$s"
}

bootstrap_escaped=$(escape_for_json "$bootstrap_content")
session_context="<EXTREMELY_IMPORTANT>\n本段由 **harness** 项目内嵌 Cursor sessionStart hook 注入。\n\n${bootstrap_escaped}\n</EXTREMELY_IMPORTANT>"

if [ -n "${CURSOR_PLUGIN_ROOT:-}" ] || [ "${_plugin_basename}" = ".cursor" ]; then
  printf '{\n  "additional_context": "%s"\n}\n' "$session_context"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$session_context"
else
  printf '{\n  "additionalContext": "%s"\n}\n' "$session_context"
fi

exit 0
